{
  "projectName": "HTML Basics - Tools Suite",
  "description": "Organized modular toolkit with shared core files",
  "organization": {
    "core": {
      "description": "Shared core files used across all modules",
      "path": "core/",
      "files": [
        {
          "name": "base-theme.js",
          "type": "JavaScript",
          "purpose": "Theme switching and dark/light mode logic"
        },
        {
          "name": "base-theme.css",
          "type": "CSS",
          "purpose": "Base theme styles applied globally"
        },
        {
          "name": "app.js",
          "type": "JavaScript",
          "purpose": "Main application logic and initialization"
        },
        {
          "name": "styles.css",
          "type": "CSS",
          "purpose": "Global CSS styles for the application"
        }
      ]
    },
    "public": {
      "description": "Public-facing entry points and assets",
      "path": "public/",
      "files": [
        {
          "name": "index.html",
          "type": "HTML",
          "purpose": "Home page and main dashboard",
          "dependencies": ["../core/base-theme.js", "../core/base-theme.css"]
        }
      ],
      "subdirectories": [
        {
          "name": "admin",
          "purpose": "Admin-related pages"
        },
        {
          "name": "register",
          "purpose": "Registration-related pages"
        },
        {
          "name": "uploads",
          "purpose": "Directory for user-uploaded files"
        }
      ]
    },
    "tools": {
      "description": "Independent modular tools",
      "path": "tools/",
      "modules": [
        {
